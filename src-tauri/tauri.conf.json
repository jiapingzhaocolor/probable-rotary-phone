{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shot List Maker",
  "version": "1.5.1",
  "identifier": "com.shotliststudio.shotlistmaker",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Shot List Maker",
        "width": 1500,
        "height": 940,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#101114",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Productivity",
    "shortDescription": "Offline shot list and storyboard maker",
    "longDescription": "A dark-mode offline production planning app for shot lists, storyboards, scene organization, CSV import and PDF exports.",
    "copyright": "Copyright \u00a9 2026 Shot List Studio",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
